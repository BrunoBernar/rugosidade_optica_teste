        toolbar_frame.pack(fill="x")
        NavigationToolbar2Tk(self.canvas, toolbar_frame).update()

        self.canvas.draw()   # renderização inicial (gráfico vazio)

    # ------------------------------------------------------------------ helpers
    def _btn(self, parent, text, cmd, color=COLOR_BTN, fg=COLOR_TEXT):
        """
        Cria e retorna um botão com estilo padronizado do tema escuro.
        Centraliza a criação para manter consistência visual em toda a UI.
        """
        return tk.Button(
            parent, text=text, command=cmd,
            bg=color, fg=fg,
            activebackground=COLOR_SEL, activeforeground="#000",
            relief="flat", bd=0, padx=8, pady=5,
            font=("Segoe UI", 9), cursor="hand2"
        )

    def _style_axes(self):
        """
        Aplica o estilo visual padrão (tema escuro, grid, rótulos de eixo)
        nos dois subgráficos.
        Deve ser chamada toda vez que os axes são limpos (ax.cla()),
        pois cla() remove todas as propriedades de estilo.
        """
        for ax, (title, color) in zip(self.axes, [("OK", COLOR_OK), ("NOK", COLOR_NOK)]):
            ax.set_facecolor("#1e1e2e")
            ax.tick_params(colors="#cdd6f4", labelsize=9)
            for sp in ax.spines.values():
                sp.set_color("#45475a")
                sp.set_linewidth(0.8)
            ax.grid(True, color="#313244", linewidth=0.6, linestyle="--", alpha=0.7)
            ax.set_title(title, color=color, fontsize=13, fontweight="bold", pad=10)
            ax.set_xlabel("Curso [mm]", color="#cdd6f4", fontsize=10)
            ax.set_ylabel("Força [kN]", color="#cdd6f4", fontsize=10)

    # ------------------------------------------------------------------ ações
    def _add_files(self):
        """
        Abre o diálogo de seleção de arquivos, carrega cada XML selecionado
        e evita duplicatas (mesmo filepath já presente na lista).
        Após carregamento bem-sucedido, atualiza lista e redesenha o gráfico.
        """
        paths = filedialog.askopenfilenames(
            title="Selecionar arquivos XML",
            filetypes=[("XML files", "*.xml"), ("All files", "*.*")]
        )
        added = 0
        for path in paths:
            # Verifica se o arquivo já foi carregado anteriormente nesta sessão
            if any(e.filepath == path for e in self.entries):
                continue
            try:
                entry = CurveEntry(path, auto_classify(path))
                self.entries.append(entry)
                added += 1
            except Exception as err:
                # Mostra erro por arquivo individualmente para não bloquear os demais
                messagebox.showerror("Erro ao carregar",
                                     f"{os.path.basename(path)}:\n{err}")
        if added:
            self._refresh_list()
            self._plot()

    def _remove_selected(self):
        """
        Remove a curva atualmente selecionada na listbox.
        Atualiza a lista e redesenha o gráfico após a remoção.
        """
        sel = self.listbox.curselection()
        if not sel:
            return
        self.entries.pop(sel[0])   # remove pelo índice da seleção
        self.detail_var.set("")    # limpa o painel de detalhes
        self._refresh_list()
        self._plot()

    def _clear_all(self):
        """
        Remove TODAS as curvas carregadas após confirmação do usuário.
        Limpa também o gráfico e reinicia o estilo dos axes.
        """
        if not self.entries:
            return
        if messagebox.askyesno("Limpar", "Remover todos os arquivos?"):
            self.entries.clear()
            self.detail_var.set("")
            self._refresh_list()
            for ax in self.axes:
                ax.cla()          # limpa completamente cada subplot
            self._style_axes()   # reaplicar estilo após cla()
            self.fig.tight_layout(pad=2.5)
            self.canvas.draw()

    def _rename_label(self):
        """
        Abre uma janela popup para editar o label de exibição da curva selecionada.
        O label é usado apenas internamente; o filepath original não é alterado.
        Confirma ao pressionar Enter ou clicar no botão.
        """
        sel = self.listbox.curselection()
        if not sel:
            messagebox.showinfo("Renomear", "Selecione um arquivo na lista primeiro.")
            return
        idx = sel[0]
        win = tk.Toplevel(self)
        win.title("Renomear")
        win.configure(bg=COLOR_PANEL)
        win.geometry("340x120")
        win.resizable(False, False)
        tk.Label(win, text="Novo label:", bg=COLOR_PANEL,
                 fg=COLOR_TEXT, font=("Segoe UI", 10)).pack(pady=(14, 4))
        ent = tk.Entry(win, font=("Segoe UI", 10), bg=COLOR_BTN,
                       fg=COLOR_TEXT, insertbackground=COLOR_TEXT, relief="flat")
        ent.insert(0, self.entries[idx].label)   # pré-preenche com o label atual
        ent.pack(padx=20, fill="x")
        ent.focus()

        def apply(e=None):
            v = ent.get().strip()
            if v:
                self.entries[idx].label = v   # salva o novo nome
            self._refresh_list()
            win.destroy()

        ent.bind("<Return>", apply)    # atalho teclado: Enter confirma
        self._btn(win, "Confirmar", apply, color=COLOR_SEL, fg="#000").pack(pady=8)

    def _set_class(self, cls):
        """
        Classifica manualmente a curva selecionada como 'OK' ou 'NOK'.
        Sobrescreve a classificação automática definida pelo nome do arquivo.
        Redesenha o gráfico para refletir a mudança imediatamente.
        """
        sel = self.listbox.curselection()
        if not sel:
            messagebox.showinfo("Classificar", "Selecione um arquivo na lista primeiro.")
            return
        self.entries[sel[0]].classification = cls
        self._refresh_list()
        self._plot()

    def _on_select(self, _event=None):
        """
        Callback chamado sempre que o usuário clica em um item da listbox.
        Exibe no painel de detalhes os metadados do XML (data, hora, ciclo)
        e estatísticas básicas da curva (número de pontos, curso e força máximos).
        """
        sel = self.listbox.curselection()
        if not sel:
            return
        e = self.entries[sel[0]]
        m = e.meta
        curso_max = f"{max(e.x):.2f}" if e.x else "-"
        forca_max = f"{max(e.y):.3f}" if e.y else "-"
        self.detail_var.set(
            f"Classe   : {e.classification} (pelo nome do arquivo)\n"
            f"Programa : {m.get('program','')}\n"
            f"Data/Hora: {m.get('date','')} {m.get('time','')}\n"
            f"Ciclo    : {m.get('cycle','')}\n"
            f"Pontos   : {len(e.x)}\n"
            f"Curso max: {curso_max} mm\n"
            f"Força max: {forca_max} kN"
        )

    # ------------------------------------------------------------------ plot
    def _plot(self):
        """
        Redesenha completamente os dois subgráficos (OK e NOK).

        Etapas:
            1. Separa as entradas em dois grupos por classificação.
            2. Limpa os axes e reaplicar o estilo.
            3. Plota cada grupo com uma paleta de cores distinta (shades).
            4. Define ticks do eixo X de 5 em 5 mm para facilitar leitura.
            5. Desenha o retângulo da janela de aprovação em amarelo sobre ambos os gráficos.
            6. Atualiza a barra de status com a contagem final.
        """
        ok_list  = [e for e in self.entries if e.classification == "OK"]
        nok_list = [e for e in self.entries if e.classification == "NOK"]

        for ax in self.axes:
            ax.cla()         # apaga tudo do axes sem destruir o objeto
        self._style_axes()   # reaplicar grid, cores, rótulos após o cla()

        max_val = self._max_curves_var.get()
        max_n = None if max_val == "Todas" else int(max_val)
        show_legend = self._legend_var.get()

        def draw_group(ax, entries, shades, title, title_color):
            n_total = len(entries)
            visible = entries[:max_n] if max_n is not None else entries
            hidden  = n_total - len(visible)
            suffix  = f" (+{hidden} oculta{'s' if hidden != 1 else ''})" if hidden else ""
            ax.set_title(
                f"{title}  ({n_total} curva{'s' if n_total != 1 else ''}){suffix}",
                color=title_color, fontsize=13, fontweight="bold", pad=10
            )
            for i, e in enumerate(visible):
                ax.plot(e.x, e.y,
                        color=shades[i % len(shades)],
                        linewidth=1.5, alpha=0.85,
                        label=e.label)
            if visible and show_legend:
                ax.legend(loc="upper left", fontsize=8,
                          facecolor="#2a2a3e", edgecolor="#45475a",
                          labelcolor="#cdd6f4", framealpha=0.9)

        draw_group(self.axes[0], ok_list,  OK_SHADES,  "OK",  COLOR_OK)
        draw_group(self.axes[1], nok_list, NOK_SHADES, "NOK", COLOR_NOK)

        # ── Ticks de 5 em 5 mm no eixo X ─────────────────────────────────────
        # Calcula os ticks com base no intervalo real dos dados carregados,
        # garantindo legibilidade independente do range do arquivo XML.
        import numpy as np
        all_x = [x for e in self.entries for x in e.x]
        if all_x:
            x_min = min(all_x)
            x_max = max(all_x)
            ticks = np.arange(
                int(x_min // 5) * 5,          # arredonda para baixo no múltiplo de 5
                int(x_max // 5) * 5 + 5 + 5,  # arredonda para cima + uma margem extra
                5
            )
            for ax in self.axes:
                ax.set_xticks(ticks)
                ax.tick_params(axis="x", labelsize=9, rotation=0)

        # ── Janela de aprovação ───────────────────────────────────────────────
        # Lê os valores dos quatro campos de entrada e desenha:
        #   - um retângulo semi-transparente amarelo (mpatches.Rectangle)
        #   - o contorno sólido do retângulo (ax.plot)
        #   - linhas horizontais pontilhadas em Y_min e Y_max para referência
        #   - labels com os valores numéricos à esquerda do retângulo
        try:
            wx0 = float(self._win_xmin.get())   # X inicial da janela [mm]
            wx1 = float(self._win_xmax.get())   # X final da janela [mm]
            wy0 = float(self._win_ymin.get())   # Y mínimo da janela [kN]
            wy1 = float(self._win_ymax.get())   # Y máximo da janela [kN]
            for ax in self.axes:
                # Preenchimento semi-transparente (alpha=0.08) para não ocultar as curvas
                ax.add_patch(mpatches.Rectangle(
                    (wx0, wy0), wx1 - wx0, wy1 - wy0,
                    linewidth=1.8, edgecolor="#f1c40f",
                    facecolor="#f1c40f", alpha=0.08, zorder=5,
                    label=f"Janela ({wx0}–{wx1} mm | {wy0}–{wy1} kN)"
                ))
                # Contorno sólido sobre o preenchimento (zorder maior = desenhado por cima)
                ax.plot([wx0, wx1, wx1, wx0, wx0],
                        [wy0, wy0, wy1, wy1, wy0],
                        color="#f1c40f", linewidth=1.8, zorder=6)
                # Linhas de referência horizontais tracejadas para facilitar leitura de Y
                ax.axhline(wy0, color="#f1c40f", linewidth=0.6, linestyle=":", alpha=0.5, zorder=4)
                ax.axhline(wy1, color="#f1c40f", linewidth=0.6, linestyle=":", alpha=0.5, zorder=4)
                # Labels numéricos posicionados à esquerda do retângulo
                ax.text(wx0 - 0.5, wy0, f"{wy0:.2f} kN", color="#f1c40f",
                        fontsize=8, va="center", ha="right", zorder=7)
                ax.text(wx0 - 0.5, wy1, f"{wy1:.2f} kN", color="#f1c40f",
                        fontsize=8, va="center", ha="right", zorder=7)
        except (ValueError, AttributeError):
            # Se algum campo estiver vazio ou inválido, simplesmente omite o retângulo
            pass

        self.fig.tight_layout(pad=2.5)
        self.canvas.draw()
        self._set_status(
            f"{len(self.entries)} curva(s) carregada(s)  —  "
            f"{len(ok_list)} OK  /  {len(nok_list)} NOK"
        )

    # ------------------------------------------------------------------ salvar
    def _save_plot(self):
        """
        Exporta o gráfico atual para um arquivo de imagem (PNG, PDF ou SVG).
        O fundo escuro do tema é preservado no arquivo exportado.
        """
        if not self.entries:
            messagebox.showinfo("Salvar", "Nenhuma curva carregada.")
            return
        path = filedialog.asksaveasfilename(
            defaultextension=".png",
            initialfile="force_curves_comparison.png",
            filetypes=[("PNG", "*.png"), ("PDF", "*.pdf"), ("SVG", "*.svg")],
            title="Salvar gráfico"
        )
        if path:
            # facecolor garante que o fundo escuro do figure seja mantido no arquivo salvo
            self.fig.savefig(path, dpi=200, bbox_inches="tight",
                             facecolor=self.fig.get_facecolor())
            self._set_status(f"Salvo: {os.path.basename(path)}")

    # ------------------------------------------------------------------ utils
    def _refresh_list(self):
        """
        Reconstrói do zero a listbox com base em self.entries.
        Cada item recebe ícone (✔/✘) e cor de acordo com a classificação da curva.
        Atualiza também a barra de status com a contagem atual.
        """
        self.listbox.delete(0, "end")
        for e in self.entries:
            icon  = "✔" if e.classification == "OK" else "✘"
            color = COLOR_OK if e.classification == "OK" else COLOR_NOK
            self.listbox.insert("end", f" {icon}  {e.label}")
            self.listbox.itemconfig("end", fg=color)  # cor do texto por item
        n_ok  = sum(1 for e in self.entries if e.classification == "OK")
        n_nok = sum(1 for e in self.entries if e.classification == "NOK")
        self._set_status(f"{len(self.entries)} arquivo(s) — {n_ok} OK / {n_nok} NOK")

    def _set_status(self, msg):
        """Atualiza a mensagem exibida na barra de status do painel esquerdo."""
        self.status_var.set(msg)


