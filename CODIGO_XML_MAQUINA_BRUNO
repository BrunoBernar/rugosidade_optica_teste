# =============================================================================
# PARSER — formato Part_protocol (Promess / Kistler)
# =============================================================================

def parse_xml(filepath):
    """
    Abre e interpreta um XML no formato Part_protocol gerado pela prensa Promess.
    Extrai metadados (data, hora, ciclo, programa) e os pontos da curva Força × Curso.

    Parâmetros:
        filepath (str): caminho completo do arquivo XML.

    Retorna:
        dict com:
            "x"    → lista de floats com posição do cursor [mm]
            "y"    → lista de floats com força medida [kN]
            "meta" → dicionário com campos de cabeçalho do arquivo

    Lança ValueError se nenhum ponto <Point> válido for encontrado.
    """
    tree = ET.parse(filepath)       # carrega o arquivo XML inteiro na memória
    root = tree.getroot()           # elemento raiz do documento XML

    meta = {}

    def gv(tag):
        """Busca um elemento pelo nome de tag em qualquer nível e retorna o atributo 'Value'."""
        el = root.find(f".//{tag}")
        return el.get("Value") if el is not None else ""

    # Extrai campos de cabeçalho que identificam o ensaio
    meta["date"]    = gv("Date")                  # data do ensaio
    meta["time"]    = gv("Time")                  # hora do ensaio
    meta["cycle"]   = gv("Cycle_number")          # número do ciclo de prensagem
    meta["program"] = gv("Measuring_program_name")# nome do programa de medição configurado na prensa
    meta["block_x"] = gv("Block_X")               # bloco de parâmetros X (referência da máquina)
    meta["block_y"] = gv("Block_Y")               # bloco de parâmetros Y (referência da máquina)

    # --- Extração dos pontos da curva ---
    xs, ys = [], []
    for pt in root.findall(".//Point"):
        # Tenta primeiro o tag com nome completo do eixo absoluto da máquina
        x_el = pt.find("X-ABSOLUTE-")
        if x_el is None:
            # Fallback: alguns XMLs usam apenas <X> sem o sufixo "-ABSOLUTE-"
            x_el = pt.find("X")
        y_el = pt.find("Y")

        # Só processa pontos onde ambos os valores existem e são conversíveis
        if x_el is not None and y_el is not None:
            try:
                # Substitui vírgula por ponto para suportar localização PT-BR
                x = float(x_el.get("Value").replace(",", "."))
                y = float(y_el.get("Value").replace(",", "."))
                xs.append(x)
                ys.append(y)
            except (ValueError, AttributeError):
                # Ignora silenciosamente pontos malformados
                pass

    if not xs:
        # Se nenhum ponto foi lido, o XML não é compatível — informa ao usuário
        raise ValueError(
            "Não foram encontrados pontos <Point> com X-ABSOLUTE- e Y no arquivo.\n"
            f"Verifique a estrutura do XML: {os.path.basename(filepath)}"
        )

    # Os valores de X representam a coordenada absoluta da máquina (não normalizados para 0).
    # Isso permite comparar curvas de ensaios diferentes sem deslocamentos artificiais.

    return {"x": xs, "y": ys, "meta": meta}


# =============================================================================
# MODELO DE DADOS — uma curva carregada
# =============================================================================

class CurveEntry:
    """
    Encapsula todos os dados de uma curva de prensagem carregada de um arquivo XML.

    Atributos:
        filepath        : caminho completo do arquivo fonte
        label           : nome de exibição (por padrão = nome do arquivo sem extensão)
        classification  : "OK" ou "NOK" — pode ser definida pelo nome do arquivo ou manualmente
        data            : dicionário retornado por parse_xml()
    """
    def __init__(self, filepath, classification):
        self.filepath       = filepath
        self.label          = os.path.splitext(os.path.basename(filepath))[0]  # nome sem .xml
        self.classification = classification
        self.data           = parse_xml(filepath)   # lê e valida o XML imediatamente

    # Propriedades de conveniência para acessar os vetores sem passar pelo dicionário
    @property
    def x(self):    return self.data["x"]       # posições [mm]
    @property
    def y(self):    return self.data["y"]       # forças [kN]
    @property
    def meta(self): return self.data["meta"]    # metadados do cabeçalho XML


def auto_classify(filepath):
    """
    Determina automaticamente se um arquivo é OK ou NOK com base EXCLUSIVAMENTE
    no nome do arquivo — nunca nos dados medidos.

    Regra de prioridade:
        - Busca "_OK" e "_NOK" no nome (maiúsculo), sem case-sensitivity.
        - Caso "_NOK" apareça DEPOIS de "_OK" no nome → NOK.
        - Caso "_OK"  apareça DEPOIS de "_NOK" no nome → OK.
        - Se nenhum dos dois for encontrado → padrão OK.

    Exemplos:
        Part__OK.xml      → OK
        Part__NOK.xml     → NOK
        Part__NOK_OK.xml  → OK  (o "_OK" aparece por último)
    """
    name = os.path.basename(filepath).upper()   # compara sempre em maiúsculas

    # Usa rfind para encontrar a ÚLTIMA ocorrência de cada tag no nome
    pos_ok  = name.rfind("_OK")
    pos_nok = name.rfind("_NOK")

    if pos_nok == -1 and pos_ok == -1:
        # Fallback: tenta sem underscore (ex: "PARTE_MEDIDANOK.xml")
        pos_ok  = name.rfind("OK")
        pos_nok = name.rfind("NOK")

    # Se nenhuma das duas strings existir, classifica como OK por padrão
    if pos_nok == -1 and pos_ok == -1:
        return "OK"
    if pos_nok == -1:
        return "OK"
    if pos_ok == -1:
        return "NOK"

    # Quem aparecer mais à direita no nome vence (ex: "_NOK_OK" → OK ganha)
    return "NOK" if pos_nok > pos_ok else "OK"


